# SimpliTrade configuration. Copy to .env and fill in. All keys have safe dev
# defaults (see internal/platform/config) — the app boots offline with none set.

# --- Runtime ---
APP_ENV=dev            # dev | prod | test  (prod refuses insecure defaults)
PORT=8080

# --- HTTP hardening ---
CORS_ALLOWED_ORIGINS=*           # comma-separated origins; use real ones in prod
RATE_LIMIT_RPS=20                # per-IP requests/second (0 disables)
RATE_LIMIT_BURST=40              # per-IP burst allowance

# --- Database (Postgres) ---
HOST=localhost
DBUSER=postgres
DBPASS=postgres
DBNAME=simplitrade
DBPORT=5432
SSLMODE=disable
TIMEZONE=UTC

# --- Auth ---
# REQUIRED in prod. In dev a throwaway secret is used if unset.
JWT_KEY=
ACCESS_TOKEN_TTL=15m   # Go duration ("15m", "1h") or bare seconds
REFRESH_TOKEN_TTL=720h # must exceed ACCESS_TOKEN_TTL

# --- Market data (added near the end of the build) ---
MARKET_PROVIDER=fake   # fake | twelvedata  (fake needs no key)
MARKET_API_KEY=        # required when MARKET_PROVIDER=twelvedata (free key from twelvedata.com)
MARKET_RATE_PER_MIN=8  # cap upstream calls/min to the provider's free-tier limit

# --- Engine (Tower 2) ---
ENGINE_TICK_INTERVAL=60s            # how often the engine refreshes + decides
ENGINE_STRATEGIES_DIR=internal/engine/strategies
