# --- Secrets & Environment Variables ---
# Ignore .env at root and in any subfolder
.env
.env.*
# Exception: allow example files so others know what keys are needed
!.env.example

# --- Go (Root Level) ---
# Binaries and build artifacts
/bin/
/dist/
*.exe
*.test
*.out
# Stray compiled binaries (`go build` with no -o lands these at root)
/main
/server
/engine
/daemon
# Engine scratch output
/output.txt

# Logs
*.log

# Temporary files
/tmp/

# --- Node / Frontend (Universal) ---
# These patterns work regardless of where frontend is located
node_modules/
.next/
coverage/
.DS_Store

# --- Project Specific Ignores ---
internal/engine/seed/mock_stocks_list.json
/TODO
devlog.md
db_comments.md
data/

# --- Local-only design docs (kept out of the repo) ---
/ARCHITECTURE.md
/BACKEND_PLAN.md
/internal/engine/strategies/SCHEMA.md

# --- Editor/IDE ---
.vscode/
.idea/



.ghcontext
